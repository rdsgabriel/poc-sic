  "implementation": {
    "tailwind4": {
      "theme": "Tokens devem ser definidos em :root/.dark e mapeados dentro de @theme inline.",
      "pattern": "--color-primary: var(--primary); --color-secondary: var(--secondary); --radius-lg: var(--radius);",
      "observacao": "Não usar hsl(var(--token)) como padrão deste projeto; o ProntuAI usa HEX direto nas variáveis."
    },
    "recommendedUsage": [
      "Usar bg-primary para ações principais de maior peso e identidade institucional.",
      "Usar bg-secondary ou text-secondary para destaque teal, estados ativos e CTAs secundários.",
      "Usar bg-card/text-card-foreground para superfícies reutilizáveis.",
      "Evitar hardcodes como #193B4F, #007891, bg-white e blue-* fora de integrações ou status específicos.",
      "Manter componentes compactos: Button h-9, Input h-9, Sidebar item h-9.",
      "Usar rounded-md para controles, rounded-xl para cards shadcn e containers maiores quando seguir o padrão atual."
    ],
    "migrationNotes": [
      "Este JSON substitui a referência PGR anterior e prioriza o visual atual do ProntuAI.",
      "A diferença mais importante é que primary permanece #193B4F, não #007891.",
      "As animações ai-chip/roadmap do guia PGR não fazem parte do ProntuAI atual; se forem desejadas em projetos futuros, devem entrar como extensão opcional, não como base."
    ]
  }
}
